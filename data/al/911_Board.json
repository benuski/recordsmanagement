    "series_metadata": {
      "series_id": null,
      "series_title": "RECEIPT SUMMARIES",
      "series_description": "A cumulative monthly record of the total number of wireless communication customers in the state maintained as a running record throughout the current fiscal year. At the end of the fiscal year the summary is filed, along with a summary of the two previous fiscal years. The number of customers determines the amount of CMRS service charges collected into the CMRS Fund and therefore sets the level of disbursement for the year.",
      "legal_citation": null
    },
